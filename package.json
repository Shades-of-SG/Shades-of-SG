{
  "name": "shades-of-sg",
  "version": "1.0.0",
  "description": "SCCCI AI Challenge - Unpaid Interns",
  "scripts": {
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "lint": "eslint backend && npm run lint --prefix frontend",
    "test": "npm run test --prefix backend && npm run test --prefix frontend",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.6.2"
  }
}
