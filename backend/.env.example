PORT=5000
NODE_ENV=development

# Supabase PostgreSQL
# Leave DATABASE_URL commented for local SQLite development.
# Uncomment and fill this only when connecting to Supabase/PostgreSQL.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres
DB_SSL=true
SEQUELIZE_LOGGING=false

# Local SQLite fallback, used only when DATABASE_URL is not set
DB_STORAGE=./database.sqlite

# Auth and media providers
# Either auth variable is accepted; set one strong, unique value in production.
JWT_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173
# Optional comma-separated additional origins, such as approved Vercel preview domains.
FRONTEND_URLS=
SEED_CREATOR_EMAIL=violet@example.com
SEED_CREATOR_PASSWORD=replace-with-local-dev-password
SEED_CREATOR_NAME=Violet
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Temporary fallback while final AI MP4 generation is incomplete.
# Use an absolute, publicly reachable URL in deployed environments. Completed jobs label it temporary.
PLACEHOLDER_VIDEO_URL=

# AI transcription
OPENAI_API_KEY=
# Whisper is required when scene generation needs segment timestamps.
# GPT-4o transcription models are also accepted, but return lyrics without segments.
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Optional YouTube audio extraction
# Leave blank if yt-dlp is available on PATH, or set to a local executable path.
YT_DLP_PATH=
